<Window x:Class="Pizzeria.Pos.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Pizzeria.Pos.Wpf.Views"
        Title="POS Pizzeria"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#141B2D">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="SquareButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallMenuButton" TargetType="Button" BasedOn="{StaticResource SquareButton}">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="78"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="SectionTileButton" TargetType="Button" BasedOn="{StaticResource SquareButton}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="92"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="SalesMainButton" TargetType="Button" BasedOn="{StaticResource SquareButton}">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="82"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="#12192A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="18,10,0,0">
                <TextBlock Text="{Binding CurrentDateTime, StringFormat={}{0:dd MMMM yyyy}}"
                           Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentDateTime, StringFormat={}{0:HH:mm:ss}}"
                           Foreground="White" FontSize="20"/>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="{Binding SectionTitle}"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" HorizontalAlignment="Right" Margin="0,10,18,0">
                <TextBlock Text="PIZZERIA POS"
                           Foreground="#3B82F6"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding CurrentUser.Name, StringFormat=Operator: {0}}"
                           Foreground="White"
                           FontSize="16"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- LEFT PANEL -->
        <Grid Grid.Row="1"
      Grid.RowSpan="2"
      Grid.Column="0"
      Margin="0,0,8,8"
      Background="#1A2336">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="12,12,12,8" Background="#22324A" Padding="10">
                <TextBlock Text="AKTYWNE ZAMÓWIENIA"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"/>
            </Border>

            <ListBox Grid.Row="1"
             Margin="12,0,12,8"
             ItemsSource="{Binding OpenOrders}"
             SelectedItem="{Binding SelectedOpenOrder}"
             BorderThickness="0"
             Background="Transparent"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F4F6F7"
                        BorderBrush="#D5D8DC"
                        BorderThickness="1"
                        Margin="0,0,0,8"
                        Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Id, StringFormat=Zamówienie #{0}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>
                                <TextBlock Text="{Binding Type, StringFormat=Typ: {0}}"
                                   FontSize="15"
                                   Foreground="#374151"
                                   Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Total, StringFormat={}{0:F2} zł}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#16A34A"
                                   Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding ItemsSummary}"
                                   FontSize="14"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2" Margin="12,0,12,8" Background="#314158" Padding="10">
                <DockPanel>
                    <TextBlock Text="Suma:"
                       Foreground="White"
                       FontSize="18"
                       DockPanel.Dock="Left"/>
                    <TextBlock Text="{Binding SelectedOpenOrder.Total, TargetNullValue=0, StringFormat={}{0:F2} zł}"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <UniformGrid Grid.Row="3" Rows="2" Columns="2" Margin="12,0,12,8">
                <Button Content="Edytuj"
            Style="{StaticResource SmallMenuButton}"
            Command="{Binding EditSelectedCommand}"/>

                <Button Content="Płać"
            Style="{StaticResource SmallMenuButton}"
            Command="{Binding PaySelectedCommand}"/>

                <Button Content="Storno"
            Style="{StaticResource SmallMenuButton}"
            Command="{Binding CancelSelectedCommand}"/>

                <Button Content="Zmień typ"
            Style="{StaticResource SmallMenuButton}"
            Command="{Binding ChangeTypeSelectedCommand}"/>
            </UniformGrid>

            <DockPanel Grid.Row="4" Margin="12,0,12,8">
                <TextBlock Text="{Binding CurrentDateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                   Foreground="#CBD5E1"
                   FontSize="12"
                   DockPanel.Dock="Left"/>
                <TextBlock Text="{Binding CurrentUser.Name}"
                   Foreground="#CBD5E1"
                   FontSize="12"
                   HorizontalAlignment="Right"/>
            </DockPanel>
        </Grid>

        <!-- CENTER -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="8,0,12,0">
            <!-- SALES -->
            <Grid Visibility="{Binding IsSalesSection, Converter={StaticResource BoolToVisibilityConverter}}"
      Background="#172033">
                <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">
                    <TextBlock Text="WYBIERZ OPCJĘ SPRZEDAŻY"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">
                        <Button Content="Na miejscu"
                    Style="{StaticResource SalesMainButton}"
                    Background="#16A34A"
                    Command="{Binding NewOrderOnSiteCommand}"/>

                        <Button Content="Wynos"
                    Style="{StaticResource SalesMainButton}"
                    Background="#0EA5E9"
                    Command="{Binding NewOrderTakeawayCommand}"/>

                        <Button Content="Dostawa"
                    Style="{StaticResource SalesMainButton}"
                    Background="#F59E0B"
                    Command="{Binding NewOrderDeliveryCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- GENERAL -->
            <ScrollViewer Visibility="{Binding IsOptionsGeneralSection, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          Background="#172033">
                <StackPanel Margin="10,10,10,0">
                    <TextBlock Text="DOKUMENTY I KARTOTEKI" Foreground="#AFC4E8" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Użytkownicy" Style="{StaticResource SectionTileButton}" Background="#1D4ED8" Foreground="White" Command="{Binding OpenUsersPanelCommand}"/>
                        <Button Content="Produkty" Style="{StaticResource SectionTileButton}" Background="#1D4ED8" Foreground="White" Command="{Binding OpenProductsCommand}"/>
                        <Button Content="Dodatki pizzy"
                                Style="{StaticResource SectionTileButton}"
                                Background="#1D4ED8"
                                Foreground="White"
                                Command="{Binding OpenPizzaAddonsCommand}"/>
                    </WrapPanel>

                    <Border Height="10" Background="#415A77" Margin="0,8,0,10"/>
                    <TextBlock Text="NARZĘDZIA" Foreground="#AFC4E8" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Ustawienia programu"
                                Style="{StaticResource SectionTileButton}"
                                Background="#12B5EA"
                                Foreground="White"
                                Command="{Binding OpenSettingsPanelCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- REGISTERS -->
            <ScrollViewer Visibility="{Binding IsOptionsRegistersSection, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          Background="#172033">
                <StackPanel Margin="10,10,10,0">
                    <TextBlock Text="REJESTRY" Foreground="#AFC4E8" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Rejestr zamówień" Style="{StaticResource SectionTileButton}" Background="#12B5EA" Foreground="White" Command="{Binding OpenRegistersCommand}"/>
                        <Button Content="Rejestr klientów" Style="{StaticResource SectionTileButton}" Background="#12B5EA" Foreground="White" Command="{Binding OpenCustomersRegisterCommand}"/>
                        <Button Content="Rejestr dostaw" Style="{StaticResource SectionTileButton}" Background="#12B5EA" Foreground="White" Command="{Binding OpenDeliveriesRegisterCommand}"/>
                        <Button Content="Rejestr rachunków" Style="{StaticResource SectionTileButton}" Background="#12B5EA" Foreground="White" Command="{Binding OpenReceiptsRegisterCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- REPORTS -->
            <ScrollViewer Visibility="{Binding IsOptionsReportsSection, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          Background="#172033">
                <StackPanel Margin="10,10,10,0">
                    <TextBlock Text="RAPORTY OGÓLNE" Foreground="#AFC4E8" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Raport&#x0a;dzienny"
                                Style="{StaticResource SectionTileButton}"
                                Background="#12B5EA" Foreground="White"
                                Command="{Binding OpenReportsCommand}"/>
                        <Button Content="Raport&#x0a;miesięczny"
                                Style="{StaticResource SectionTileButton}"
                                Background="#0D9488" Foreground="White"
                                Command="{Binding OpenMonthlyReportCommand}"/>
                        <Button Content="Raport&#x0a;POS"
                                Style="{StaticResource SectionTileButton}"
                                Background="#DC2626" Foreground="White"
                                Command="{Binding PrintPosReportCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- USERS -->
            <Grid Visibility="{Binding IsUsersPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                  Background="#172033">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="10">
                    <TextBlock Text="UŻYTKOWNICY" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <Button Content="Powrót"
                            DockPanel.Dock="Right"
                            Width="140"
                            Height="44"
                            Background="#64748B"
                            Foreground="White"
                            Command="{Binding CloseUsersPanelCommand}"/>
                </DockPanel>

                <views:UsersPanel Grid.Row="1"
                            Grid.Column="1"
                            DataContext="{Binding UserManagement}"/>
            </Grid>

            <!-- SETTINGS -->
            <Grid Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
      Background="#172033">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="10">
                    <TextBlock Text="USTAWIENIA PROGRAMU"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"/>

                    <Button Content="Powrót"
                DockPanel.Dock="Right"
                Width="140"
                Height="44"
                Background="#64748B"
                Foreground="White"
                Command="{Binding CloseSettingsPanelCommand}"/>
                </DockPanel>

                <views:SettingsPanel Grid.Row="1"
                         DataContext="{Binding SettingsPanel}"/>
            </Grid>

        </Grid>

        <!-- BOTTOM -->
        <Grid Grid.Row="2"
      Grid.Column="1"
      Background="Transparent"
      Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="14,0,0,0">
                <Button Content="Sprzedaż" Width="120" Height="72" Margin="4"
                Style="{StaticResource SquareButton}"
                Command="{Binding ShowSalesCommand}"/>
                <Button Content="Ogólne" Width="120" Height="72" Margin="4"
                Style="{StaticResource SquareButton}"
                Command="{Binding ShowOptionsGeneralCommand}"/>
                <Button Content="Rejestry" Width="120" Height="72" Margin="4"
                Style="{StaticResource SquareButton}"
                Command="{Binding ShowOptionsRegistersCommand}"/>
                <Button Content="Raporty" Width="120" Height="72" Margin="4"
                Style="{StaticResource SquareButton}"
                Command="{Binding ShowOptionsReportsCommand}"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,0">
                <Button Content="Wyloguj&#x0a;[ESC]"
                Width="92" Height="72" Margin="4"
                Style="{StaticResource SquareButton}"
                Command="{Binding LogoutCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>