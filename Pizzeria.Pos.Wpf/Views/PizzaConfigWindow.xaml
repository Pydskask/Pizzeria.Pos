<Window x:Class="Pizzeria.Pos.Wpf.Views.PizzaConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja pizzy"
        Height="820"
        Width="1280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Window.Resources>
        <!-- Kafelek RadioButton (rozmiar / ciasto) -->
        <Style x:Key="TileRadio" TargetType="RadioButton">
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Margin"                     Value="0,0,0,8"/>
            <Setter Property="Height"                     Value="68"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background"                 Value="#0F172A"/>
            <Setter Property="BorderBrush"                Value="#334155"/>
            <Setter Property="BorderThickness"            Value="2"/>
            <Setter Property="Padding"                    Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#1E3A5F"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Przycisk kategorii dodatku -->
        <Style x:Key="CategoryBtn" TargetType="RadioButton">
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Margin"                     Value="0,0,0,8"/>
            <Setter Property="Height"                     Value="52"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background"                 Value="#0F172A"/>
            <Setter Property="BorderBrush"                Value="#334155"/>
            <Setter Property="BorderThickness"            Value="2"/>
            <Setter Property="Padding"                    Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#1E3A5F"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kafelek CheckBox (dodatki) -->
        <Style x:Key="TileCheck" TargetType="CheckBox">
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Margin"                     Value="0,0,0,8"/>
            <Setter Property="Height"                     Value="64"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background"                 Value="#0F172A"/>
            <Setter Property="BorderBrush"                Value="#334155"/>
            <Setter Property="BorderThickness"            Value="2"/>
            <Setter Property="Padding"                    Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#14532D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#16A34A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4ADE80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Duży przycisk akcji -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"          Value="60"/>
            <Setter Property="FontSize"        Value="18"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20,14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding PizzaName}"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"/>
                    <TextBlock Text="Wybierz rozmiar, ciasto i dodatki"
                               Foreground="#94A3B8"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#0B1220"
                        BorderBrush="#1E3A8A"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20,10">
                    <StackPanel>
                        <TextBlock Text="Aktualna cena"
                                   Foreground="#93C5FD"
                                   FontSize="13"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:F2} zł}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- GŁÓWNA TREŚĆ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Lewa: Rozmiar + Ciasto -->
                <ColumnDefinition Width="260"/>
                <!-- Środu: Kategorie dodatków -->
                <ColumnDefinition Width="220"/>
                <!-- Prawa: Lista dodatków z wybranej kategorii -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEWA: Rozmiar + Ciasto -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROZMIAR -->
                <Border Grid.Row="0"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="ROZMIAR"
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <RadioButton x:Name="Size30Radio"
                                     GroupName="SizeGroup"
                                     Checked="Size30Checked"
                                     Style="{StaticResource TileRadio}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="30 cm" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Cena bazowa" Foreground="#94A3B8" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="+0,00 zł"
                                           Foreground="#38BDF8" FontSize="15" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="Size40Radio"
                                     GroupName="SizeGroup"
                                     Checked="Size40Checked"
                                     Style="{StaticResource TileRadio}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="40 cm" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Większa pizza" Foreground="#94A3B8" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="+10,00 zł"
                                           Foreground="#38BDF8" FontSize="15" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="Size50Radio"
                                     GroupName="SizeGroup"
                                     Checked="Size50Checked"
                                     Style="{StaticResource TileRadio}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="50 cm" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Największy wariant" Foreground="#94A3B8" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="+18,00 zł"
                                           Foreground="#38BDF8" FontSize="15" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- CIASTO -->
                <Border Grid.Row="2"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="CIASTO"
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <RadioButton x:Name="DoughThinRadio"
                                     GroupName="DoughGroup"
                                     Checked="DoughThinChecked"
                                     Style="{StaticResource TileRadio}">
                            <StackPanel>
                                <TextBlock Text="Cienkie" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Lżejsze, chrupiące" Foreground="#94A3B8" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="DoughTraditionalRadio"
                                     GroupName="DoughGroup"
                                     Checked="DoughTraditionalChecked"
                                     Style="{StaticResource TileRadio}">
                            <StackPanel>
                                <TextBlock Text="Tradycyjne" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Klasyczne ciasto" Foreground="#94A3B8" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ŚRODEK: Kategorie dodatków -->
            <Border Grid.Column="1"
                    Background="#1E293B"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock Text="KATEGORIE"
                               Foreground="#94A3B8"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               DockPanel.Dock="Top"/>

                    <ItemsControl ItemsSource="{Binding AddonGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="AddonCategoryGroup"
                                             Style="{StaticResource CategoryBtn}"
                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                             Command="{Binding DataContext.SelectAddonGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                             CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding GroupName}"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="#334155"
                                                CornerRadius="10"
                                                Padding="6,2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedCount}"
                                                       Foreground="#38BDF8"
                                                       FontSize="13"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- PRAWA: Dodatki z wybranej kategorii -->
            <Border Grid.Column="2"
                    Background="#1E293B"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14">
                <DockPanel>
                    <TextBlock Text="{Binding SelectedAddonGroup.GroupName, FallbackValue='Wybierz kategorię'}"
                               Foreground="#94A3B8"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,0,0,12"
                               DockPanel.Dock="Top"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedAddonGroup.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource TileCheck}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Price, StringFormat={}{0:F2} zł}"
                                                       Foreground="#38BDF8"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"/>
                                        </Grid>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="✖  Anuluj"
                    Style="{StaticResource ActionBtn}"
                    Background="#475569"
                    Command="{Binding CancelCommand}"/>

            <Button Grid.Column="2"
                    Content="✔  Dodaj do zamówienia"
                    Style="{StaticResource ActionBtn}"
                    Background="#16A34A"
                    Command="{Binding ConfirmCommand}"/>
        </Grid>
    </Grid>
</Window>
