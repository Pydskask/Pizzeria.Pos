<Window x:Class="Pizzeria.Pos.Wpf.Views.PizzaConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja pizzy"
        Height="860"
        Width="1460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Window.Resources>
        <SolidColorBrush x:Key="PageBgBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="CardBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#F8FAFC"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="TileRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="98"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Height" Value="94"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DCFCE7"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#86EFAC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP -->
        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="22"
                Padding="22"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding PizzaName}"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Skonfiguruj pizzę, wybierz rozmiar, dodatki i ciasto."
                               FontSize="15"
                               Foreground="#CBD5E1"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#0B1220"
                        BorderBrush="#1E3A8A"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Aktualna cena"
                                   FontSize="14"
                                   Foreground="#93C5FD"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:F2} zł}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Rozmiar pizzy"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Jeden rozmiar musi być zawsze aktywny."
                                   Style="{StaticResource SectionHintStyle}"/>

                        <RadioButton x:Name="Size30Radio"
                                     GroupName="SizeGroup"
                                     Checked="Size30Checked"
                                     Style="{StaticResource TileRadioButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="30 cm" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Cena bazowa" FontSize="14" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="+0,00 zł"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="Size40Radio"
                                     GroupName="SizeGroup"
                                     Checked="Size40Checked"
                                     Style="{StaticResource TileRadioButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="40 cm" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Większa pizza" FontSize="14" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="+10,00 zł"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="Size50Radio"
                                     GroupName="SizeGroup"
                                     Checked="Size50Checked"
                                     Style="{StaticResource TileRadioButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="50 cm" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Największy wariant" FontSize="14" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="+18,00 zł"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Typy dodatków"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="W tej wersji to tylko układ pod przyszłe dynamiczne grupy z bazy."
                                   Style="{StaticResource SectionHintStyle}"/>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,10">
                            <TextBlock Text="Serowe"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8"/>
                        </Border>

                        <Border Background="#FEF2F2"
                                BorderBrush="#FECACA"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,10">
                            <TextBlock Text="Mięsne"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#B91C1C"/>
                        </Border>

                        <Border Background="#FFFBEB"
                                BorderBrush="#FDE68A"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                            <TextBlock Text="Sosy"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#B45309"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- CENTER -->
            <ScrollViewer Grid.Column="1"
              VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Dodatki"
                       Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="Lista ładowana z bazy."
                       Style="{StaticResource SectionHintStyle}"/>

                        <ItemsControl ItemsSource="{Binding AddonGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="{Binding GroupName}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected}"
                                                  Style="{StaticResource TileCheckBoxStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="330"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"
                                                               FontSize="24"
                                                               FontWeight="Bold"/>
                                                                <TextBlock Text="{Binding GroupName}"
                                                               FontSize="14"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Margin="0,4,0,0"/>
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="1"
                                                           Text="{Binding Price, StringFormat={}{0:F2} zł}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- BOTTOM -->
        <Border Grid.Row="2"
                Background="#111827"
                CornerRadius="22"
                Padding="18"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Grubość ciasta"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Zostawiamy tylko cienkie i tradycyjne."
                               FontSize="14"
                               Foreground="#CBD5E1"
                               Margin="0,4,0,14"/>

                    <UniformGrid Columns="2">
                        <RadioButton x:Name="DoughThinRadio"
                                     GroupName="DoughGroup"
                                     Checked="DoughThinChecked"
                                     Style="{StaticResource TileRadioButtonStyle}"
                                     Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Cienkie" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="Lżejsze, bardziej chrupiące" FontSize="14" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="DoughTraditionalRadio"
                                     GroupName="DoughGroup"
                                     Checked="DoughTraditionalChecked"
                                     Style="{StaticResource TileRadioButtonStyle}"
                                     Margin="0">
                            <StackPanel>
                                <TextBlock Text="Tradycyjne" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="Klasyczne ciasto pizzerii" FontSize="14" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Anuluj"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="{StaticResource DangerBrush}"
                        Command="{Binding CancelCommand}"/>

                <Button Grid.Column="3"
                        Content="Dodaj do zamówienia"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="{StaticResource SuccessBrush}"
                        Command="{Binding ConfirmCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>