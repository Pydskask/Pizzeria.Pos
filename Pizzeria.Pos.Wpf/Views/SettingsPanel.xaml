<UserControl x:Class="Pizzeria.Pos.Wpf.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="500"
             MinWidth="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#243447"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="USTAWIENIA PROGRAMU"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Wygląd i zachowanie aplikacji"
                           Foreground="#AFC4E8"
                           FontSize="15"
                           Margin="0,0,0,18"/>

                <Border Background="#1E293B"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Podgląd"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <Border Background="{Binding PreviewAccentBrush}"
                                CornerRadius="8"
                                Height="70"
                                Margin="0,0,0,10">
                            <TextBlock Text="Przycisk główny"
                                       Foreground="White"
                                       FontSize="{Binding PreviewFontSize}"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10">
                            <StackPanel>
                                <TextBlock Text="Rozmiar tekstu"
                                           Foreground="#0F172A"
                                           FontSize="14"/>
                                <TextBlock Text="{Binding FontSizeSummary}"
                                           Foreground="#334155"
                                           FontSize="{Binding PreviewFontSize}"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="#1E293B"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Status"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#FCD34D"
                                   FontSize="16"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Konfiguracja interfejsu"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,0,0,18"/>

                <StackPanel Grid.Row="1"
                            Margin="0,0,0,16">
                    <TextBlock Text="Motyw"
                               FontSize="16"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              Height="42"
                              FontSize="17"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,0,0,16">
                    <TextBlock Text="Kolor akcentu"
                               FontSize="16"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AccentOptions}"
                              SelectedItem="{Binding SelectedAccent, Mode=TwoWay}"
                              Height="42"
                              FontSize="17"/>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Margin="0,0,0,16">
                    <TextBlock Text="Rozmiar czcionki"
                               FontSize="16"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding FontSizeOptions}"
                              SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}"
                              Height="42"
                              FontSize="17"/>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Margin="0,0,0,16">
                    <CheckBox Content="Tryb dotykowy / większe elementy"
                              IsChecked="{Binding IsTouchMode, Mode=TwoWay}"
                              FontSize="17"
                              Margin="0,0,0,8"/>
                    <CheckBox Content="Pokazuj komunikaty potwierdzające zapis"
                              IsChecked="{Binding ShowSaveConfirmation, Mode=TwoWay}"
                              FontSize="17"/>
                </StackPanel>

                <Border Grid.Row="5"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Opis"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Na ten moment panel zapisuje ustawienia w pamięci działania aplikacji. W kolejnym kroku można to podpiąć pod plik konfiguracyjny lub bazę."
                                   FontSize="15"
                                   Foreground="#475569"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <UniformGrid Grid.Row="6"
                             Columns="3"
                             Margin="0,10,0,0">
                    <Button Content="Domyślne"
                            Margin="6"
                            Height="56"
                            FontSize="18"
                            Background="#64748B"
                            Foreground="White"
                            Command="{Binding ResetDefaultsCommand}"/>

                    <Button Content="Zapisz"
                            Margin="6"
                            Height="56"
                            FontSize="18"
                            Background="#16A34A"
                            Foreground="White"
                            Command="{Binding SaveCommand}"/>

                    <Button Content="Odśwież podgląd"
                            Margin="6"
                            Height="56"
                            FontSize="18"
                            Background="#2563EB"
                            Foreground="White"
                            Command="{Binding RefreshPreviewCommand}"/>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>