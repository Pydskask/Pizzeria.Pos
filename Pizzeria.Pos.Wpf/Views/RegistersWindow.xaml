<Window x:Class="Pizzeria.Pos.Wpf.Views.RegistersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestr zamówień"
        Height="900" Width="1450"
        WindowStartupLocation="CenterOwner"
        Background="#1F2937">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="REJESTR ZAMÓWIEŃ"
                   Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Data od" Foreground="White" Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Height="40"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Data do" Foreground="White" Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding DateTo}" Height="40"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                <TextBlock Text="Typ" Foreground="White" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding TypeOptions}"
                          SelectedItem="{Binding SelectedType}" Height="40"/>
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                <TextBlock Text="Status" Foreground="White" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}" Height="40"/>
            </StackPanel>

            <Button Grid.Column="4" Content="Filtruj"
                    Height="40" Margin="0,22,8,0"
                    Command="{Binding ApplyFiltersCommand}"/>
            <Button Grid.Column="5" Content="Wyczyść"
                    Height="40" Margin="0,22,8,0"
                    Command="{Binding ClearFiltersCommand}"/>
            <Button Grid.Column="6" Content="Odśwież"
                    Height="40" Margin="0,22,8,0"
                    Command="{Binding LoadOrdersCommand}"/>
            <Button Grid.Column="7" Content="Zamknij"
                    Height="40" Margin="0,22,0,0"
                    Background="#DC2626"
                    Command="{Binding CloseCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="4"
                    Padding="10" Margin="0,0,15,0">
                <DataGrid ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedOrder}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="Typ" Binding="{Binding TypeLabel}" Width="110"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120"/>
                        <DataGridTextColumn Header="Kwota" Binding="{Binding Total, StringFormat=F2}" Width="100"/>
                        <DataGridTextColumn Header="Płatność" Binding="{Binding PaymentMethod}" Width="110"/>
                        <DataGridTextColumn Header="Operator" Binding="{Binding OperatorName}" Width="130"/>
                        <DataGridTextColumn Header="Pozycje" Binding="{Binding ItemsSummary}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="15"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="SZCZEGÓŁY"
                                   Foreground="#F8FAFC"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding DetailsText}"
                                       Foreground="#CBD5E1"
                                       FontSize="14"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="1" Columns="1">
                    <Button Content="Wydrukuj ponownie BON kuchni"
                            Height="55" Margin="0,0,0,8"
                            Background="#2563EB"
                            Command="{Binding ReprintKitchenBonCommand}"/>
                    <Button Content="Wydrukuj ponownie BON dostawcy"
                            Height="55" Margin="0,0,0,8"
                            Background="#8B5CF6"
                            Command="{Binding ReprintDeliveryBonCommand}"/>
                    <Button Content="Wydrukuj ponownie paragon"
                            Height="55" Margin="0,0,0,8"
                            Background="#16A34A"
                            Command="{Binding ReprintReceiptCommand}"/>
                    <Button Content="Odśwież wybrane"
                            Height="55"
                            Command="{Binding RefreshSelectedCommand}"/>
                </UniformGrid>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="#FCD34D" FontSize="16" Margin="0,15,0,0"/>
    </Grid>
</Window>