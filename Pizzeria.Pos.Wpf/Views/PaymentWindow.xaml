<Window x:Class="Pizzeria.Pos.Wpf.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Płatność"
        Height="820"
        Width="1366"
        MinHeight="768"
        MinWidth="1280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827"/>
        <SolidColorBrush x:Key="PanelBrushAlt" Color="#1E293B"/>
        <SolidColorBrush x:Key="PanelBrushSoft" Color="#0F172A"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#334155"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#355C8A"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#416A99"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#2C4D73"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C0392B"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8"/>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrushAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="#922B21"/>
        </Style>

        <Style x:Key="FinishButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="62"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
            <Setter Property="BorderBrush" Value="#166534"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="KeypadButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="#1E3A5F"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <Style x:Key="MiniDiscountButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Background" Value="#1D4ED8"/>
        </Style>

        <Style x:Key="ValueDisplayButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PanelBrushSoft}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.75"/>
                                <Setter TargetName="Root" Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- STYL KAFELKA FORMY PŁATNOŚCI -->
        <Style x:Key="PaymentMethodButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectedMethodBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#355C8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#22324A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#22324A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#172554"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="PŁATNOŚĆ"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Rozliczenie zamówienia"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*"/>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="0.82*"/>
            </Grid.ColumnDefinitions>

            <!-- LEWA -->
            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="POZYCJE ZAMÓWIENIA"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding CartItems}"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0,0,0,8"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Produkt" Width="250" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Ilość" Width="58" DisplayMemberBinding="{Binding Quantity}"/>
                                <GridViewColumn Header="Cena" Width="88" DisplayMemberBinding="{Binding UnitPrice, StringFormat={}{0:F2} zł}"/>
                                <GridViewColumn Header="Razem" Width="98" DisplayMemberBinding="{Binding LineTotal, StringFormat={}{0:F2} zł}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border Grid.Row="2"
                            Background="{StaticResource PanelBrushSoft}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="RABAT %"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <Button Content="-5%"
                                            Style="{StaticResource MiniDiscountButtonStyle}"
                                            Command="{Binding ApplyDiscountPercentCommand}"
                                            CommandParameter="5"/>
                                    <Button Content="-10%"
                                            Style="{StaticResource MiniDiscountButtonStyle}"
                                            Command="{Binding ApplyDiscountPercentCommand}"
                                            CommandParameter="10"/>
                                    <Button Content="-15%"
                                            Style="{StaticResource MiniDiscountButtonStyle}"
                                            Command="{Binding ApplyDiscountPercentCommand}"
                                            CommandParameter="15"/>
                                    <Button Content="-20%"
                                            Style="{StaticResource MiniDiscountButtonStyle}"
                                            Command="{Binding ApplyDiscountPercentCommand}"
                                            CommandParameter="20"/>
                                </WrapPanel>
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Content="Usuń rabat"
                                    Width="132"
                                    Height="40"
                                    Margin="10,22,0,0"
                                    FontSize="15"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding ClearDiscountCommand}"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ŚRODEK -->
            <Grid Grid.Column="1" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ROZLICZENIE"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding OrderTotal, StringFormat=Kwota bazowa: {0:F2} zł}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       Margin="0,2"/>

                            <TextBlock Text="{Binding DiscountAmount, StringFormat=Rabat: -{0:F2} zł}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       Margin="0,2"/>

                            <TextBlock Text="{Binding AmountPaid, StringFormat=Wpłacono: {0:F2} zł}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       Margin="0,2"/>

                            <TextBlock Text="{Binding RemainingAmount, StringFormat=Pozostało: {0:F2} zł}"
                                       Foreground="#FBBF24"
                                       FontSize="16"
                                       Margin="0,2"/>

                            <TextBlock Text="{Binding ChangeAmount, StringFormat=Reszta: {0:F2} zł}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       Margin="0,2"/>

                            <TextBlock Text="{Binding SelectedMethod, StringFormat=Forma płatności: {0}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       Margin="0,2"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="{StaticResource PanelBrushSoft}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="10,8"
                                Margin="10,0,0,0"
                                VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="DO ZAPŁATY"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding FinalTotal, StringFormat={}{0:F2} zł}"
                                           Foreground="#86EFAC"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="WPŁACONO"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource ValueDisplayButtonStyle}"
                                Command="{Binding FocusAmountPaidCommand}"
                                IsEnabled="{Binding CanEditAmountPaid}">
                            <TextBlock Text="{Binding AmountPaidText}"
                                       Foreground="White"
                                       FontSize="20"/>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="RABAT KW."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource ValueDisplayButtonStyle}"
                                Command="{Binding FocusCustomDiscountCommand}">
                            <TextBlock Text="{Binding CustomDiscountText}"
                                       Foreground="White"
                                       FontSize="20"/>
                        </Button>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="3"
                             Rows="4"
                             Columns="3"
                             Margin="0,0,0,6">
                    <Button Content="1" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="1"/>
                    <Button Content="2" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="2"/>
                    <Button Content="3" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="3"/>
                    <Button Content="4" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="4"/>
                    <Button Content="5" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="5"/>
                    <Button Content="6" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="6"/>
                    <Button Content="7" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="7"/>
                    <Button Content="8" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="8"/>
                    <Button Content="9" Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}" CommandParameter="9"/>
                    <Button Content=","
                            Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter=","/>
                    <Button Content="0"
                            Style="{StaticResource KeypadButtonStyle}"
                            Command="{Binding AppendDigitCommand}"
                            CommandParameter="0"/>
                    <Button Content="C"
                            Style="{StaticResource KeypadButtonStyle}"
                            Background="{StaticResource WarningBrush}"
                            Command="{Binding BackspaceCommand}"/>
                </UniformGrid>

                <Button Grid.Row="4"
                        Content="Wyczyść pole"
                        Height="42"
                        FontSize="16"
                        Margin="3,0,3,0"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding ClearActiveInputCommand}"/>
            </Grid>

            <!-- PRAWA -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="FORMY PŁATNOŚCI"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,10"/>

                        <Button Content="Gotówka"
                                Style="{StaticResource PaymentMethodButtonStyle}"
                                Background="#2563EB"
                                Command="{Binding SelectCashCommand}"/>

                        <Button Content="Karta"
                                Style="{StaticResource PaymentMethodButtonStyle}"
                                Background="#2563EB"
                                Command="{Binding SelectCardCommand}"/>

                        <Button Content="Przelew"
                                Style="{StaticResource PaymentMethodButtonStyle}"
                                Background="#2563EB"
                                Command="{Binding SelectTransferCommand}"/>

                        <Button Content="Online"
                                Style="{StaticResource PaymentMethodButtonStyle}"
                                Background="#2563EB"
                                Command="{Binding SelectOnlineCommand}"/>

                        <Button Content="Voucher"
                                Style="{StaticResource PaymentMethodButtonStyle}"
                                Background="#2563EB"
                                Margin="0"
                                Command="{Binding SelectVoucherCommand}"/>
                    </StackPanel>
                </Border>

                <Button Grid.Row="2"
                        Content="GOTOWE / PARAGON"
                        Style="{StaticResource FinishButtonStyle}"
                        Command="{Binding FinishPaymentCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>