<Window x:Class="Pizzeria.Pos.Wpf.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Zamówienie"
        Height="800"
        Width="1280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#0F172A">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#1E293B"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16,12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TitleText}"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding OrderContextText}"
                               Foreground="#94A3B8"
                               FontSize="14"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✏ Edytuj dane dostawy"
                        Height="40"
                        Padding="16,0"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Click="EditDelivery_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Background" Value="#2563EB"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OrderType}" Value="D">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- GŁÓWNA TREŚĆ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- KATEGORIE -->
            <Border Grid.Column="0"
                    Background="#1E293B"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,10,0">
                <Grid Cursor="">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="KATEGORIE"
                               Foreground="#94A3B8"
                               FontSize="13"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="16">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1E3A5F"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- PRODUKTY -->
            <Border Grid.Column="1"
                    Background="#1E293B"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock Text="PRODUKTY"
                               Foreground="#94A3B8"
                               FontSize="13"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               DockPanel.Dock="Top"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Products}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,6"
                                            Padding="12,10"
                                            HorizontalContentAlignment="Stretch"
                                            Background="#0F172A"
                                            Foreground="White"
                                            BorderBrush="#334155"
                                            BorderThickness="1"
                                            Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1E3A5F"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Price, StringFormat={}{0:F2} zł}"
                                                       Foreground="#38BDF8"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- KOSZYK -->
            <Border Grid.Column="2"
                    Background="#1E293B"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="KOSZYK"
                               Foreground="#94A3B8"
                               FontSize="13"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="#0F172A"
                              AlternatingRowBackground="#111827"
                              Foreground="White"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#1E293B"
                              Margin="0,0,0,10">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#0F172A"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="#334155"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Cena"
                                                Binding="{Binding UnitPrice, StringFormat={}{0:F2} zł}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Ilość"
                                                Binding="{Binding Quantity}"
                                                Width="70"/>
                            <DataGridTextColumn Header="Razem"
                                                Binding="{Binding LineTotal, StringFormat={}{0:F2} zł}"
                                                Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- DOLNA CZĘŚĆ KOSZYKA -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- SUMA -->
                        <Border Grid.Row="0"
                                Background="#0F172A"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,0,0,10">
                            <TextBlock Text="{Binding CartTotal, StringFormat=SUMA: {0:F2} zł}"
                                       Foreground="#38BDF8"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Border>

                        <!-- PRZYCISKI EDYCJI -->
                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,8">
                            <Button Content="-1"
                                    Height="48"
                                    Margin="0,0,4,0"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Background="#475569"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding DecreaseQuantityCommand}"
                                    IsEnabled="{Binding CanModifySelectedItem}"/>
                            <Button Content="+1"
                                    Height="48"
                                    Margin="4,0"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Background="#475569"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding IncreaseQuantityCommand}"
                                    IsEnabled="{Binding CanModifySelectedItem}"/>
                            <Button Content="✏ Edytuj pizzę"
                                    Height="48"
                                    Margin="4,0"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#D97706"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding EditSelectedPizzaCommand}"
                                    IsEnabled="{Binding CanEditSelectedPizza}"/>
                            <Button Content="🗑 Usuń"
                                    Height="48"
                                    Margin="4,0,0,0"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#DC2626"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding RemoveSelectedItemCommand}"
                                    IsEnabled="{Binding CanModifySelectedItem}"/>
                        </UniformGrid>

                        <!-- PRZYCISKI NAWIGACJI -->
                        <UniformGrid Grid.Row="2" Columns="3">
                            <Button Content="💾 Zapisz i wróć"
                                    Height="52"
                                    Margin="0,0,4,0"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#475569"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding SaveAndBackCommand}"/>
                            <Button Content="💳 Płatność"
                                    Height="52"
                                    Margin="4,0"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#16A34A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding GoToPaymentCommand}"/>
                            <Button Content="✖ Anuluj"
                                    Height="52"
                                    Margin="4,0,0,0"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#6B7280"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Command="{Binding CancelCommand}"/>
                        </UniformGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>