<Window x:Class="Pizzeria.Pos.Wpf.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Zamówienie"
        Height="760"
        Width="1280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14"
                Margin="0,0,0,12"
                Background="#FFF4F4F4"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="{Binding TitleText}"
                           FontSize="24"
                           FontWeight="Bold"/>

                <TextBlock Text="{Binding OrderContextText}"
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="#FF444444"
                           TextWrapping="Wrap"/>

                <Button Content="Edytuj dane dostawy"
                        Width="180"
                        Height="36"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Click="EditDelivery_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OrderType}" Value="D">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Margin="0,0,12,0"
                    Background="#FFF7F7F7"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Kategorie"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             MinHeight="420"/>

                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Padding="12"
                    Margin="0,0,12,0"
                    Background="#FFF7F7F7"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock Text="Produkty"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               DockPanel.Dock="Top"/>
                    
                    <ListBox ItemsSource="{Binding Products}"
         SelectedItem="{Binding SelectedProduct, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,8"
                    Padding="10"
                    HorizontalContentAlignment="Stretch"
                    Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />

                                        <TextBlock Grid.Column="1"
                               Text="{Binding Price, StringFormat={}{0:F2} zł}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="#FFF7F7F7"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Koszyk"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Cena"
                                                Binding="{Binding UnitPrice, StringFormat={}{0:F2} zł}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Ilość"
                                                Binding="{Binding Quantity}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Razem"
                                                Binding="{Binding LineTotal, StringFormat={}{0:F2} zł}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,15,0,15">
                            <Button Content="-1"
        Width="90"
        Height="50"
        Margin="5"
        FontSize="20"
        Command="{Binding DecreaseQuantityCommand}"
        IsEnabled="{Binding CanModifySelectedItem}" />

                            <Button Content="+1"
        Width="90"
        Height="50"
        Margin="5"
        FontSize="20"
        Command="{Binding IncreaseQuantityCommand}"
        IsEnabled="{Binding CanModifySelectedItem}" />

                            <Button Content="Edytuj pizzę"
            Width="172"
            Height="50"
            Margin="5"
            FontSize="18"
            Background="#F39C12"
            Foreground="White"
            Command="{Binding EditSelectedPizzaCommand}"
            IsEnabled="{Binding CanEditSelectedPizza}"/>
                            
                            <Button Content="Usuń"
        Width="110"
        Height="50"
        Margin="5"
        FontSize="20"
        Background="#E74C3C"
        Foreground="White"
        Command="{Binding RemoveSelectedItemCommand}"
        IsEnabled="{Binding CanModifySelectedItem}" />
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding CartTotal, StringFormat=SUMA: {0:F2} zł}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="0,15,162,75" Grid.RowSpan="2" Width="452">
                            <Button Content="Zapisz i wróć"
                                    Width="140"
                                    Height="42"
                                    Margin="0,0,8,0"
                                    Command="{Binding SaveAndBackCommand}"/>

                            <Button Content="Płatność"
                                    Width="120"
                                    Height="42"
                                    Margin="0,0,8,0"
                                    Command="{Binding GoToPaymentCommand}"/>

                            <Button Content="Anuluj"
                                    Width="100"
                                    Height="42"
                                    Command="{Binding CancelCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>