<Window x:Class="Pizzeria.Pos.Wpf.Views.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Produkty - Konfiguracja"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2C3E50"
                Padding="20"
                Margin="0,0,0,20"
                CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRODUKTY"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="16"
                           Foreground="#F39C12"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="8">
                <DataGrid ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="50"
                          Margin="15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nazwa"
                                            Binding="{Binding Name}"
                                            Width="3*"/>
                        <DataGridTextColumn Header="Cena"
                                            Binding="{Binding Price, StringFormat={}{0:F2}}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Kategoria"
                                            Binding="{Binding Category}"
                                            Width="1.5*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="15,0,15,0">
                <Button Content="Nowy"
                        Height="50"
                        Margin="0,10"
                        FontSize="16"
                        Command="{Binding NewProductCommand}"
                        Background="#27AE60"
                        Foreground="White"/>

                <Button Content="Usuń"
                        Height="50"
                        Margin="0,10"
                        FontSize="16"
                        Command="{Binding DeleteSelectedCommand}"
                        Background="#E74C3C"
                        Foreground="White"/>

                <Button Content="Odśwież"
                        Height="50"
                        Margin="0,10"
                        FontSize="16"
                        Command="{Binding RefreshCommand}"
                        Background="#3498DB"
                        Foreground="White"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                Padding="20"
                Margin="0,20,0,0"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    <TextBlock Text="Nazwa"
                               FontSize="14"
                               Margin="0,0,5,0" Height="46"/>
                    <TextBlock Text="Cena"
                               FontSize="14"
                               Margin="0,10,5,0" Height="48"/>
                    <TextBlock Text="Kategoria"
                               FontSize="14"
                               Margin="0,10,5,0" Height="33" RenderTransformOrigin="0.688,1.743"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,20,0">
                    <TextBox x:Name="NameTextBox"
         Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
         Height="45"
         FontSize="18"
         Margin="0,0,0,10"
         IsReadOnly="True"
         Cursor="Hand"
         PreviewMouseDown="NameTextBox_PreviewMouseDown"/>

                    <TextBox x:Name="PriceTextBox"
         Text="{Binding NewProductPrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
         Height="45"
         FontSize="18"
         Margin="0,0,0,10"
         IsReadOnly="True"
         Cursor="Hand"
         PreviewMouseDown="PriceTextBox_PreviewMouseDown"/>

                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding NewProductCategory, Mode=TwoWay}"
                              Height="45"
                              FontSize="18"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Bottom">
                    <Button Content="{Binding SaveButtonText}"
                            Width="170"
                            Height="50"
                            Margin="0,0,0,10"
                            FontSize="16"
                            Command="{Binding SaveProductCommand}"
                            Background="#16A34A"
                            Foreground="White"/>

                    <Button Content="Anuluj edycję"
                            Width="170"
                            Height="50"
                            FontSize="16"
                            Command="{Binding CancelEditCommand}"
                            Background="#6B7280"
                            Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>