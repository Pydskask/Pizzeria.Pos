<Window x:Class="Pizzeria.Pos.Wpf.Views.CustomersRegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestr klientów"
        Height="850" Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="#1F2937">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="REJESTR KLIENTÓW"
                   Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Odśwież" Height="40" Width="120" Margin="0,0,10,0"
                    Command="{Binding LoadCommand}"/>
            <Button Content="Zamknij" Height="40" Width="120"
                    Background="#6B7280" Command="{Binding CloseCommand}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="0" Padding="10" Margin="0,0,15,0">
                <DataGrid ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="140"/>
                        <DataGridTextColumn Header="Imię i nazwisko" Binding="{Binding Name}" Width="200"/>
                        <DataGridTextColumn Header="Adres" Binding="{Binding Address}" Width="*"/>
                        <DataGridTextColumn Header="Zamówień" Binding="{Binding OrderCount}" Width="100"/>
                        <DataGridTextColumn Header="Łącznie" Binding="{Binding TotalSpent, StringFormat=F2}" Width="110"/>
                        <DataGridTextColumn Header="Ostatnie" Binding="{Binding LastOrderDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="0" Padding="15">
                <DockPanel>
                    <TextBlock Text="SZCZEGÓŁY KLIENTA" FontSize="20" FontWeight="Bold"
                               Margin="0,0,0,12" DockPanel.Dock="Top"/>
                    <TextBox Text="{Binding DetailsText}" IsReadOnly="True"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14" FontFamily="Consolas"
                             BorderThickness="0" Background="White"/>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="#FCD34D" FontSize="16" Margin="0,15,0,0"/>
    </Grid>
</Window>