<Window x:Class="Pizzeria.Pos.Wpf.Views.DeliveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dostawa / Odbiór"
        Height="900"
        Width="1360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#566573"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TouchDisplayTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FDFEFE"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaymentButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Telefon" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="PhoneTextBox"
                             Style="{StaticResource TouchDisplayTextBoxStyle}"
                             Tag="Numeric"
                             Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PreviewMouseDown="InputTextBox_PreviewMouseDown"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Nazwa klienta" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="CustomerNameTextBox"
                             Style="{StaticResource TouchDisplayTextBoxStyle}"
                             Tag="Alpha"
                             Text="{Binding CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PreviewMouseDown="InputTextBox_PreviewMouseDown"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Znajdź"
                        Margin="0,19,0,0"
                        Height="48"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding SearchPhoneCommand}"/>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <!-- SAVED ADDRESSES -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,12,0">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="ZAPISANE ADRESY"
                               DockPanel.Dock="Top"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding SavedAddresses}"
                             SelectedItem="{Binding SelectedSavedAddress, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="White"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,8"
                                        Padding="10"
                                        HorizontalContentAlignment="Stretch"
                                        Background="#F8F9F9"
                                        BorderBrush="#D5DBDB"
                                        BorderThickness="1"
                                        Command="{Binding DataContext.SelectSavedAddressCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#1F2937"/>
                                        <TextBlock Text="{Binding DisplayAddress}"
                                                   FontSize="14"
                                                   Foreground="#34495E"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Notes}"
                                                   FontSize="12"
                                                   Foreground="#7F8C8D"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- RIGHT SIDE -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ADDRESS -->
                <Border Grid.Row="0"
                        Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                                   Text="DANE ADRESOWE"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Miasto"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox x:Name="CityTextBox"
                                 Grid.Row="1" Grid.Column="1"
                                 Style="{StaticResource TouchDisplayTextBoxStyle}"
                                 Tag="Alpha"
                                 Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,10,10"
                                 PreviewMouseDown="InputTextBox_PreviewMouseDown"/>

                        <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="Ulica"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox x:Name="StreetTextBox"
                                 Grid.Row="1" Grid.Column="3"
                                 Style="{StaticResource TouchDisplayTextBoxStyle}"
                                 Tag="Alpha"
                                 Text="{Binding Street, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"
                                 PreviewMouseDown="InputTextBox_PreviewMouseDown"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Nr domu"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox x:Name="HouseNumberTextBox"
                                 Grid.Row="2" Grid.Column="1"
                                 Style="{StaticResource TouchDisplayTextBoxStyle}"
                                 Tag="Alpha"
                                 Text="{Binding HouseNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,10,10"
                                 PreviewMouseDown="InputTextBox_PreviewMouseDown"/>

                        <TextBlock Grid.Row="2" Grid.Column="2"
                                   Text="Nr lokalu"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox x:Name="ApartmentNumberTextBox"
                                 Grid.Row="2" Grid.Column="3"
                                 Style="{StaticResource TouchDisplayTextBoxStyle}"
                                 Tag="Alpha"
                                 Text="{Binding ApartmentNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"
                                 PreviewMouseDown="InputTextBox_PreviewMouseDown"/>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Kod"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox x:Name="PostalCodeTextBox"
                                 Grid.Row="3" Grid.Column="1"
                                 Style="{StaticResource TouchDisplayTextBoxStyle}"
                                 Tag="Numeric"
                                 Text="{Binding PostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,10,0"
                                 PreviewMouseDown="InputTextBox_PreviewMouseDown"/>

                        <TextBlock Grid.Row="3" Grid.Column="2"
                                   Text="Cena"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox x:Name="DeliveryPriceTextBox"
                                 Grid.Row="3" Grid.Column="3"
                                 Style="{StaticResource TouchDisplayTextBoxStyle}"
                                 Tag="Numeric"
                                 Text="{Binding DeliveryPrice, Mode=TwoWay, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewMouseDown="InputTextBox_PreviewMouseDown"/>
                    </Grid>
                </Border>

                <!-- BOTTOM AREA -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <!-- DETAILS -->
                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Text="SZCZEGÓŁY"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,10"/>

                            <!--<TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Termin"
                                       Style="{StaticResource FieldLabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>

                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Height="48"
                                     FontSize="18"
                                     Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,0,10"
                                     IsReadOnly="True"
                                     Background="#F8F9F9"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Text="{Binding DeliveryTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/> -->

                            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45*"/>
                                    <ColumnDefinition Width="26*"/>
                                    <ColumnDefinition Width="333*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Uwagi"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Margin="0,0,0,6" Grid.ColumnSpan="3"/>

                                <TextBox x:Name="NotesTextBox"
                                         Grid.Row="1"
                                         Tag="Alpha"
                                         Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True"
                                         Cursor="Hand"
                                         FontSize="17"
                                         Padding="12,10"
                                         MinHeight="220"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#FDFEFE"
                                         BorderBrush="#BDC3C7"
                                         BorderThickness="1"
                                         PreviewMouseDown="InputTextBox_PreviewMouseDown" Grid.ColumnSpan="3" Margin="0,46,0,59"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- PAYMENT -->
                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="PŁATNOŚĆ"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,10"/>

                            <UniformGrid Grid.Row="1"
                                         Columns="2"
                                         Margin="0,0,0,10">
                                <Button Style="{StaticResource PaymentButtonStyle}"
                                        Content="Gotówka"
                                        Background="#27AE60"
                                        Command="{Binding SelectCashCommand}"/>
                                <Button Style="{StaticResource PaymentButtonStyle}"
                                        Content="Karta"
                                        Background="#3498DB"
                                        Command="{Binding SelectCardCommand}"/>
                                <Button Style="{StaticResource PaymentButtonStyle}"
                                        Content="Przelew"
                                        Background="#9B59B6"
                                        Command="{Binding SelectTransferCommand}"/>
                                <Button Style="{StaticResource PaymentButtonStyle}"
                                        Content="Online"
                                        Background="#16A085"
                                        Command="{Binding SelectOnlineCommand}"/>
                                <Button Style="{StaticResource PaymentButtonStyle}"
                                        Content="Voucher"
                                        Background="#7F8C8D"
                                        Command="{Binding SelectVoucherCommand}"/>
                            </UniformGrid>

                            <Border Grid.Row="2"
                                    Background="#F8F9F9"
                                    BorderBrush="#D5DBDB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedPaymentMethod, StringFormat=Wybrano: {0}}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="#2C3E50"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding DeliveryPrice, StringFormat=Cena dostawy: {0:F2} zł}"
                                               FontSize="15"
                                               Foreground="#4B5563"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="#2C3E50"
                CornerRadius="10"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="165"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Style="{StaticResource ActionButtonStyle}"
                        Content="Wróć"
                        Background="#6B7280"
                        Command="{Binding CancelCommand}"/>

                <Button Grid.Column="3"
                        Style="{StaticResource ActionButtonStyle}"
                        Content="OK"
                        Background="#16A34A"
                        Command="{Binding ConfirmCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>