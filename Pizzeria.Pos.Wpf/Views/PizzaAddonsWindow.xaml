<Window x:Class="Pizzeria.Pos.Wpf.Views.PizzaAddonsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodatki do pizzy"
        Height="760"
        Width="1320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1F2937">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2C3E50"
                Padding="20"
                Margin="0,0,0,20"
                CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="DODATKI DO PIZZY"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="16"
                           Foreground="#F39C12"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Lista dodatków"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Addons}"
                              SelectedItem="{Binding SelectedAddon, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              RowHeight="48">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="2.2*"/>
                            <DataGridTextColumn Header="Grupa" Binding="{Binding GroupName}" Width="1.6*"/>
                            <DataGridTextColumn Header="Cena" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="1*"/>
                            <DataGridTextColumn Header="Sort." Binding="{Binding SortOrder}" Width="0.8*"/>
                            <DataGridCheckBoxColumn Header="Aktywny" Binding="{Binding IsActive}" Width="0.9*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0">
                        <Button Content="Odśwież"
                                Width="120"
                                Height="44"
                                Margin="0,0,10,0"
                                FontSize="15"
                                Command="{Binding LoadAddonsCommand}"
                                Background="#2563EB"
                                Foreground="White"/>
                        <Button Content="Nowy"
                                Width="120"
                                Height="44"
                                Margin="0,0,10,0"
                                FontSize="15"
                                Command="{Binding NewAddonCommand}"
                                Background="#16A34A"
                                Foreground="White"/>
                        <Button Content="Ukryj"
                                Width="120"
                                Height="44"
                                Margin="0,0,10,0"
                                FontSize="15"
                                Command="{Binding DeleteSelectedCommand}"
                                Background="#DC2626"
                                Foreground="White"/>
                        <Button Content="Aktywuj / ukryj"
                                Width="140"
                                Height="44"
                                FontSize="15"
                                Command="{Binding ToggleActiveCommand}"
                                Background="#D97706"
                                Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#F8FAFC"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Edycja dodatku"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,18"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Nazwa" FontSize="14" Margin="0,0,0,6"/>
                        <TextBox x:Name="AddonNameTextBox"
             Text="{Binding AddonName, UpdateSourceTrigger=PropertyChanged}"
             Height="42"
             FontSize="18"
             IsReadOnly="True"
             Cursor="Hand"
             Tag="Alpha"
             PreviewMouseDown="InputTextBoxPreviewMouseDown"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,12">
                        <TextBlock Text="Grupa" FontSize="14" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Groups}"
              SelectedItem="{Binding AddonGroupName, Mode=TwoWay}"
              Height="42"
              FontSize="18"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,12">
                        <TextBlock Text="Cena" FontSize="14" Margin="0,0,0,6"/>
                        <TextBox x:Name="AddonPriceTextBox"
             Text="{Binding AddonPrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
             Height="42"
             FontSize="18"
             IsReadOnly="True"
             Cursor="Hand"
             Tag="Numeric"
             PreviewMouseDown="InputTextBoxPreviewMouseDown"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,0,0,12">
                        <TextBlock Text="Kolejność sortowania" FontSize="14" Margin="0,0,0,6"/>
                        <TextBox x:Name="AddonSortOrderTextBox"
             Text="{Binding AddonSortOrder, UpdateSourceTrigger=PropertyChanged}"
             Height="42"
             FontSize="18"
             IsReadOnly="True"
             Cursor="Hand"
             Tag="Numeric"
             PreviewMouseDown="InputTextBoxPreviewMouseDown"/>
                    </StackPanel>

                    <CheckBox Grid.Row="5"
                              Content="Dodatek aktywny"
                              IsChecked="{Binding AddonIsActive}"
                              FontSize="18"
                              VerticalAlignment="Top"
                              Margin="0,6,0,0"/>

                    <StackPanel Grid.Row="6" Margin="0,20,0,0">
                        <Button Content="{Binding SaveButtonText}"
                                Height="50"
                                Margin="0,0,0,10"
                                FontSize="16"
                                Command="{Binding SaveAddonCommand}"
                                Background="#16A34A"
                                Foreground="White"/>

                        <Button Content="Anuluj edycję"
                                Height="50"
                                Margin="0,0,0,10"
                                FontSize="16"
                                Command="{Binding CancelEditCommand}"
                                Background="#6B7280"
                                Foreground="White"/>

                        <Button Content="Zamknij"
                                Height="50"
                                FontSize="16"
                                Command="{Binding CloseCommand}"
                                Background="#1E293B"
                                Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>