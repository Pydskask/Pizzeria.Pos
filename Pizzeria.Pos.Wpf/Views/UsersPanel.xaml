<UserControl x:Class="Pizzeria.Pos.Wpf.Views.UsersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="500"
             MinWidth="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#243447"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="UŻYTKOWNICY"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Users}"
                         SelectedItem="{Binding SelectedUser}"
                         FontSize="18">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="#F4F6F7"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Role, StringFormat=Rola: {0}}"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding Pin, StringFormat=PIN: {0}}"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding IsActive, StringFormat=Aktywny: {0}}"
                                               FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2"
                        Content="Odśwież"
                        Height="50"
                        Margin="0,10,0,0"
                        FontSize="18"
                        Command="{Binding LoadUsersCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="#F8F9F9"
                CornerRadius="10"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="EDYCJA UŻYTKOWNIKA"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="Imię" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox x:Name="NameTextBox"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="18"
                             Height="42"
                             IsReadOnly="True"
                             Cursor="Hand"
                             PreviewMouseDown="NameTextBox_PreviewMouseDown"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Text="PIN (4 cyfry)" FontSize="16" Margin="0,0,0,5"/>
                    <TextBox x:Name="PinTextBox"
                             Text="{Binding Pin, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="18"
                             Height="42"
                             MaxLength="4"
                             IsReadOnly="True"
                             Cursor="Hand"
                             PreviewMouseDown="PinTextBox_PreviewMouseDown"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,12">
                    <TextBlock Text="Rola" FontSize="16" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedRole}"
                              FontSize="18"
                              Height="42"/>
                </StackPanel>

                <CheckBox Grid.Row="4"
                          Content="Aktywny"
                          IsChecked="{Binding IsActive}"
                          FontSize="18"
                          Margin="0,6,0,18"/>

                <TextBlock Grid.Row="5"
                           Text="{Binding StatusMessage}"
                           FontSize="16"
                           Foreground="#2E86C1"
                           VerticalAlignment="Top"/>

                <UniformGrid Grid.Row="6" Columns="3" Margin="0,20,0,0">
                    <Button Content="Nowy"
                            Margin="6"
                            Height="56"
                            FontSize="18"
                            Command="{Binding NewUserCommand}"/>

                    <Button Content="Zapisz"
                            Margin="6"
                            Height="56"
                            FontSize="18"
                            Background="#27AE60"
                            Foreground="White"
                            Command="{Binding SaveUserCommand}"/>

                    <Button Content="Dezaktywuj"
                            Margin="6"
                            Height="56"
                            FontSize="18"
                            Background="#E67E22"
                            Foreground="White"
                            Command="{Binding DeactivateUserCommand}"/>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>