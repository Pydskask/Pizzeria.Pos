<Window x:Class="Pizzeria.Pos.Wpf.Views.ReceiptsRegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestr rachunków"
        Height="850" Width="1300"
        WindowStartupLocation="CenterOwner"
        Background="#1F2937">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="REJESTR RACHUNKÓW"
                   Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Data od" Foreground="White" Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Height="40"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Data do" Foreground="White" Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding DateTo}" Height="40"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                <TextBlock Text="Płatność" Foreground="White" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding PaymentOptions}"
                          SelectedItem="{Binding SelectedPayment}" Height="40"/>
            </StackPanel>

            <Button Grid.Column="3" Content="Filtruj"
                    Height="40" Margin="0,22,8,0"
                    Command="{Binding ApplyFiltersCommand}"/>

            <Button Grid.Column="4" Content="Zamknij"
                    Height="40" Margin="0,22,0,0"
                    Background="#6B7280" Command="{Binding CloseCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="0" Padding="10" Margin="0,0,15,0">
                <DataGrid ItemsSource="{Binding Receipts}"
                          SelectedItem="{Binding SelectedReceipt}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="Typ" Binding="{Binding TypeLabel}" Width="110"/>
                        <DataGridTextColumn Header="Kwota" Binding="{Binding Total, StringFormat=F2}" Width="110"/>
                        <DataGridTextColumn Header="Płatność" Binding="{Binding PaymentMethod}" Width="120"/>
                        <DataGridTextColumn Header="Operator" Binding="{Binding OperatorName}" Width="140"/>
                        <DataGridTextColumn Header="Pozycje" Binding="{Binding ItemsSummary}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="0" Padding="15">
                <DockPanel>
                    <TextBlock Text="SZCZEGÓŁY RACHUNKU" FontSize="20" FontWeight="Bold"
                               Margin="0,0,0,12" DockPanel.Dock="Top"/>
                    <TextBox Text="{Binding DetailsText}" IsReadOnly="True"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14" FontFamily="Consolas"
                             BorderThickness="0" Background="White"/>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="#FCD34D" FontSize="16" Margin="0,15,0,0"/>
    </Grid>
</Window>