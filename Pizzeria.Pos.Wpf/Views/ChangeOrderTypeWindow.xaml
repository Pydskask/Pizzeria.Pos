<Window x:Class="Pizzeria.Pos.Wpf.Views.ChangeOrderTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zmiana typu zamówienia"
        Height="420"
        Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0B1220">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#111827"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#334155"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C0392B"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="TypeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="54" />
            <Setter Property="Width" Value="160" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="ZMIANA TYPU ZAMÓWIENIA"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentTypeText, RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="18"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Background="{StaticResource PanelAltBrush}">
            <UniformGrid Columns="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="NA MIEJSCU&#x0a;M"
                        Tag="M"
                        Background="{StaticResource PrimaryBrush}"
                        Style="{StaticResource TypeButtonStyle}"
                        Click="TypeButtonClick"/>

                <Button Content="WYNOS&#x0a;W"
                        Tag="W"
                        Background="{StaticResource WarningBrush}"
                        Style="{StaticResource TypeButtonStyle}"
                        Click="TypeButtonClick"/>

                <Button Content="DOSTAWA&#x0a;D"
                        Tag="D"
                        Background="{StaticResource SuccessBrush}"
                        Style="{StaticResource TypeButtonStyle}"
                        Click="TypeButtonClick"/>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Wybierz nowy typ zamówienia."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Anuluj"
                        Background="{StaticResource DangerBrush}"
                        Style="{StaticResource FooterButtonStyle}"
                        Click="CancelClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>