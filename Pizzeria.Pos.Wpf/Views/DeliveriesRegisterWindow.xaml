<Window x:Class="Pizzeria.Pos.Wpf.Views.DeliveriesRegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestr dostaw"
        Height="850" Width="1300"
        WindowStartupLocation="CenterOwner"
        Background="#1F2937">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="REJESTR DOSTAW"
                   Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Data od" Foreground="White" Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Height="40"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Data do" Foreground="White" Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding DateTo}" Height="40"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                <TextBlock Text="Status" Foreground="White" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}" Height="40"/>
            </StackPanel>

            <Button Grid.Column="3" Content="Filtruj"
                    Height="40" Margin="0,22,8,0"
                    Command="{Binding ApplyFiltersCommand}"/>

            <Button Grid.Column="4" Content="Zamknij"
                    Height="40" Margin="0,22,0,0"
                    Background="#DC2626" Command="{Binding CloseCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,15,0">
                <DataGrid ItemsSource="{Binding Deliveries}"
                          SelectedItem="{Binding SelectedDelivery}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="Klient" Binding="{Binding CustomerName}" Width="160"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130"/>
                        <DataGridTextColumn Header="Adres" Binding="{Binding Address}" Width="*"/>
                        <DataGridTextColumn Header="Kwota" Binding="{Binding Total, StringFormat=F2}" Width="100"/>
                        <DataGridTextColumn Header="Płatność" Binding="{Binding PaymentMethod}" Width="110"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    Background="#1E293B"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="SZCZEGÓŁY DOSTAWY"
                               Foreground="#F8FAFC"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding DetailsText}"
                                   Foreground="#CBD5E1"
                                   FontSize="14"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="#FCD34D" FontSize="16" Margin="0,15,0,0"/>
    </Grid>
</Window>