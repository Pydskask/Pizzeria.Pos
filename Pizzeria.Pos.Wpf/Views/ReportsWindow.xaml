<Window x:Class="Pizzeria.Pos.Wpf.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raporty"
        Height="850"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#1F2937">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="RAPORTY I ROZLICZENIE DNIA"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <TextBlock Text="Data raportu"
                           Foreground="White"
                           FontSize="16"
                           Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding SelectedDate}"
                            Height="42"
                            FontSize="16"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Załaduj"
                    Height="42"
                    Margin="0,22,10,0"
                    FontSize="16"
                    Command="{Binding LoadDailyReportCommand}"/>

            <Button Grid.Column="2"
                    Content="Wydruk raportu"
                    Height="42"
                    Margin="0,22,10,0"
                    FontSize="16"
                    Background="#2563EB"
                    Foreground="White"
                    Command="{Binding PrintDailyReportCommand}"/>

            <Button Grid.Column="3"
                    Content="Rozliczenie dnia"
                    Height="42"
                    Margin="0,22,10,0"
                    FontSize="16"
                    Background="#16A34A"
                    Foreground="White"
                    Command="{Binding CloseDayCommand}"/>

            <Button Grid.Column="4"
                    Content="Zamknij"
                    Height="42"
                    Margin="0,22,0,0"
                    FontSize="16"
                    Background="#6B7280"
                    Foreground="White"
                    Command="{Binding CloseCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="PODSUMOWANIE"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="{Binding TotalOrders, StringFormat=Liczba zamówień: {0}}"
                               FontSize="18"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding PaidOrders, StringFormat=Opłacone: {0}}"
                               FontSize="18"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding CanceledOrders, StringFormat=Anulowane: {0}}"
                               FontSize="18"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="{Binding GrossTotal, StringFormat=Obrót brutto: {0:F2} zł}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding CashTotal, StringFormat=Gotówka: {0:F2} zł}"
                               FontSize="16"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding CardTotal, StringFormat=Karta: {0:F2} zł}"
                               FontSize="16"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding TransferTotal, StringFormat=Przelew: {0:F2} zł}"
                               FontSize="16"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding OnlineTotal, StringFormat=Online: {0:F2} zł}"
                               FontSize="16"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding VoucherTotal, StringFormat=Voucher: {0:F2} zł}"
                               FontSize="16"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="15">
                <DockPanel>
                    <TextBlock Text="PODGLĄD RAPORTU"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"
                               DockPanel.Dock="Top"/>

                    <TextBox Text="{Binding ReportText}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="18"
                             FontFamily="Consolas"
                             BorderThickness="0"
                             Background="White"/>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="#FCD34D"
                   FontSize="16"
                   Margin="0,15,0,0"/>
    </Grid>
</Window>