<Window x:Class="Pizzeria.Pos.Wpf.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raporty"
        Height="850" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#1F2937">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="RAPORTY"
                   Foreground="White" FontSize="28" FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <TabControl x:Name="MainTabControl"
                    Grid.Row="1"
                    Background="#374151"
                    BorderBrush="#4B5563"
                    Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </TabControl.Resources>

            <!-- RAPORT DZIENNY -->
            <TabItem Header="📅 Raport dzienny">
                <Grid Margin="15" Background="#1F2937">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Data raportu" Foreground="White" FontSize="15" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding SelectedDate}" Height="42" FontSize="15"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Załaduj"
                                Height="42" Margin="0,22,10,0" FontSize="15"
                                Command="{Binding LoadDailyReportCommand}"/>
                        <Button Grid.Column="2" Content="Wydruk raportu"
                                Height="42" Margin="0,22,10,0" FontSize="15"
                                Background="#2563EB"
                                Command="{Binding PrintDailyReportCommand}"/>
                        <Button Grid.Column="3" Content="Rozliczenie dnia"
                                Height="42" Margin="0,22,10,0" FontSize="15"
                                Background="#16A34A"
                                Command="{Binding CloseDayCommand}"/>
                        <Button Grid.Column="4" Content="Zamknij"
                                Height="42" Margin="0,22,0,0" FontSize="15"
                                Background="#DC2626"
                                Command="{Binding CloseCommand}"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- PODSUMOWANIE -->
                        <Border Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="16"
                                Margin="0,0,12,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="PODSUMOWANIE"
                                               Foreground="#F8FAFC"
                                               FontSize="16" FontWeight="Bold"
                                               Margin="0,0,0,14"/>
                                    <TextBlock Text="{Binding TotalOrders, StringFormat=Liczba zamówień: {0}}"
                                               Foreground="#CBD5E1" FontSize="15" Margin="0,0,0,7"/>
                                    <TextBlock Text="{Binding PaidOrders, StringFormat=Opłacone: {0}}"
                                               Foreground="#CBD5E1" FontSize="15" Margin="0,0,0,7"/>
                                    <TextBlock Text="{Binding CanceledOrders, StringFormat=Anulowane: {0}}"
                                               Foreground="#CBD5E1" FontSize="15" Margin="0,0,0,16"/>
                                    <TextBlock Text="{Binding GrossTotal, StringFormat=Obrót brutto: {0:F2} zł}"
                                               Foreground="#86EFAC" FontSize="17" FontWeight="Bold"
                                               Margin="0,0,0,10"/>
                                    <Separator Background="#334155" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding CashTotal, StringFormat=Gotówka: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding CardTotal, StringFormat=Karta: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding TransferTotal, StringFormat=Przelew: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding OnlineTotal, StringFormat=Online: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding VoucherTotal, StringFormat=Voucher: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- PODGLĄD RAPORTU -->
                        <Border Grid.Column="1"
                                Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="PODGLĄD RAPORTU"
                                           Foreground="#F8FAFC"
                                           FontSize="16" FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock Text="{Binding ReportText}"
                                               Foreground="#CBD5E1"
                                               FontSize="14"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap"
                                               LineHeight="22"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                               Foreground="#FCD34D" FontSize="15" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- RAPORT MIESIĘCZNY -->
            <TabItem Header="📊 Raport miesięczny">
                <Grid Margin="15" Background="#1F2937">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Miesiąc" Foreground="White" FontSize="15" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding MonthOptions}"
                                      SelectedItem="{Binding SelectedMonth}"
                                      Height="42" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Rok" Foreground="White" FontSize="15" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding YearOptions}"
                                      SelectedItem="{Binding SelectedYear}"
                                      Height="42" FontSize="15"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Załaduj"
                                Height="42" Margin="0,22,10,0" FontSize="15"
                                Command="{Binding LoadMonthlyReportCommand}"/>
                        <Button Grid.Column="3" Content="Wydruk raportu"
                                Height="42" Margin="0,22,10,0" FontSize="15"
                                Background="#2563EB"
                                Command="{Binding PrintMonthlyReportCommand}"/>
                        <Button Grid.Column="4" Content="Zamknij"
                                Height="42" Margin="0,22,0,0" FontSize="15"
                                Background="#DC2626"
                                Command="{Binding CloseCommand}"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="16"
                                Margin="0,0,12,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="PODSUMOWANIE"
                                               Foreground="#F8FAFC"
                                               FontSize="16" FontWeight="Bold"
                                               Margin="0,0,0,14"/>
                                    <TextBlock Text="{Binding MonthTotalOrders, StringFormat=Liczba zamówień: {0}}"
                                               Foreground="#CBD5E1" FontSize="15" Margin="0,0,0,7"/>
                                    <TextBlock Text="{Binding MonthPaidOrders, StringFormat=Opłacone: {0}}"
                                               Foreground="#CBD5E1" FontSize="15" Margin="0,0,0,7"/>
                                    <TextBlock Text="{Binding MonthCanceledOrders, StringFormat=Anulowane: {0}}"
                                               Foreground="#CBD5E1" FontSize="15" Margin="0,0,0,16"/>
                                    <TextBlock Text="{Binding MonthGrossTotal, StringFormat=Obrót brutto: {0:F2} zł}"
                                               Foreground="#86EFAC" FontSize="17" FontWeight="Bold"
                                               Margin="0,0,0,10"/>
                                    <Separator Background="#334155" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding MonthCashTotal, StringFormat=Gotówka: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding MonthCardTotal, StringFormat=Karta: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding MonthTransferTotal, StringFormat=Przelew: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding MonthOnlineTotal, StringFormat=Online: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding MonthVoucherTotal, StringFormat=Voucher: {0:F2} zł}"
                                               Foreground="#CBD5E1" FontSize="14"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="PODGLĄD RAPORTU"
                                           Foreground="#F8FAFC"
                                           FontSize="16" FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock Text="{Binding MonthReportText}"
                                               Foreground="#CBD5E1"
                                               FontSize="14"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap"
                                               LineHeight="22"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{Binding MonthStatusMessage}"
                               Foreground="#FCD34D" FontSize="15" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>